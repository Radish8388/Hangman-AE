<Window x:Class="Hangman.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman"
        mc:Ignorable="d"
        Title="Hangman"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_KeyDown"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize"
        Height="475" Width="600">
    <Grid>
        <Button Content="New Word" Width="75" Height="32" Margin="23,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="NewWord_Click" IsDefault="True"/>
        <Canvas x:Name="canvas" Width="450" Height="180" Margin="124,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Image x:Name="hangman" Width="137" Height="181" Margin="40,218,0,0"
            HorizontalAlignment="Left" VerticalAlignment="Top" Source="/hm7.png"/>
        <WrapPanel x:Name="Letters" Height="200" Width="300" Margin="259,218,0,0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Button Content="A" x:Name="btnA" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="B" x:Name="btnB" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="C" x:Name="btnC" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="D" x:Name="btnD" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="E" x:Name="btnE" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="F" x:Name="btnF" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="G" x:Name="btnG" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="H" x:Name="btnH" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="I" x:Name="btnI" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="J" x:Name="btnJ" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="K" x:Name="btnK" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="L" x:Name="btnL" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="M" x:Name="btnM" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="N" x:Name="btnN" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="O" x:Name="btnO" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="P" x:Name="btnP" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="Q" x:Name="btnQ" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="R" x:Name="btnR" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="S" x:Name="btnS" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="T" x:Name="btnT" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="U" x:Name="btnU" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="V" x:Name="btnV" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="W" x:Name="btnW" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="X" x:Name="btnX" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="Y" x:Name="btnY" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
            <Button Content="Z" x:Name="btnZ" Background="White" FontSize="24" Width="30" Height="35" Margin="5" Click="Letter_Click"/>
        </WrapPanel>

    </Grid>
</Window>
